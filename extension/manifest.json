{
  "manifest_version": 3,
  "name": "Claude Shift",
  "description": "複数のClaudeアカウントの使用状況を一元管理 (claude-shift連携)",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1:19867/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Shift"
  }
}
